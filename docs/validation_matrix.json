{
  "version": 1,
  "description": "Validation command selector for Mythic Edge workflow threads. Commands are advisory unless a current issue, contract, or CI gate makes them required.",
  "baseline_commands": [
    {
      "command": "git diff --check",
      "reason": "Catch whitespace and patch hygiene problems."
    },
    {
      "command": "py tools\\check_protected_surfaces.py --base {base}",
      "reason": "Classify protected, forbidden, local, generated, and workflow authority surfaces."
    },
    {
      "command": "py tools\\check_secret_patterns.py --all",
      "reason": "Scan tracked files for high-confidence secret and webhook URL leaks."
    }
  ],
  "surfaces": [
    {
      "id": "agent_workflow_docs",
      "risk": "medium",
      "path_globs": [
        "AGENTS.md",
        "docs/agent_constitution.md",
        "docs/agent_rules.yml",
        "docs/agent_threads/**",
        "docs/codex_skills/**",
        "docs/codex_module_workflow.md",
        "docs/templates/**",
        ".github/ISSUE_TEMPLATE/**",
        ".github/pull_request_template.md"
      ],
      "commands": [
        "py tools\\check_agent_docs.py",
        "py tools\\check_role_scope.py --role <role> --base {base}"
      ],
      "reason": "Workflow authority changes are allowed only when the current issue/contract authorizes them and role docs stay internally consistent."
    },
    {
      "id": "parser_truth_core",
      "risk": "high",
      "path_globs": [
        "src/mythic_edge_parser/app/state.py",
        "src/mythic_edge_parser/app/models.py",
        "src/mythic_edge_parser/app/extractors.py",
        "src/mythic_edge_parser/app/event_identity.py",
        "tests/test_state.py",
        "tests/test_app_models.py",
        "tests/test_app_extractors.py",
        "tests/test_event_identity.py"
      ],
      "commands": [
        "py -m pytest -q tests\\test_state.py tests\\test_app_models.py tests\\test_app_extractors.py tests\\test_event_identity.py",
        "py -m pytest -q tests\\test_parser_regressions.py",
        "py -m pytest -q tests\\test_event_schema_snapshots.py"
      ],
      "reason": "Core parser truth changes must protect match/game interpretation, finality, identity, and schema surfaces."
    },
    {
      "id": "parser_event_and_router_surfaces",
      "risk": "high",
      "path_globs": [
        "src/mythic_edge_parser/events.py",
        "src/mythic_edge_parser/router.py",
        "src/mythic_edge_parser/parsers/**",
        "tests/test_*parser*.py",
        "tests/test_router_*.py",
        "tests/test_event_schema_snapshots.py"
      ],
      "commands": [
        "py -m pytest -q tests\\test_event_schema_snapshots.py",
        "py -m pytest -q tests\\test_parsers.py tests\\test_parser_small_modules.py tests\\test_router_unit.py tests\\test_router_smoke.py"
      ],
      "reason": "Parser event and routing changes can drift event kinds, payload keys, and shared parser behavior."
    },
    {
      "id": "workbook_webhook_apps_script",
      "risk": "high",
      "path_globs": [
        "src/mythic_edge_parser/app/sheet_schema.py",
        "src/mythic_edge_parser/app/sheet_exports.py",
        "src/mythic_edge_parser/app/outputs.py",
        "tools/google_apps_script/**",
        "tests/test_sheet_schema.py",
        "tests/test_sheet_exports.py",
        "tests/test_app_outputs.py"
      ],
      "commands": [
        "py -m pytest -q tests\\test_sheet_schema.py tests\\test_sheet_exports.py tests\\test_app_outputs.py",
        "py -m pytest -q tests\\test_event_schema_snapshots.py",
        "py tools\\report_workbook_state.py"
      ],
      "reason": "Workbook-connected changes must distinguish repo code, deployed Apps Script, and live workbook state."
    },
    {
      "id": "local_generated_artifacts",
      "risk": "medium",
      "path_globs": [
        "data/**",
        "tests/fixtures/**",
        "src/mythic_edge_parser/app/config.py"
      ],
      "commands": [
        "py tools\\check_local_environment.py --profile clean_clone",
        "py tools\\check_secret_patterns.py --all"
      ],
      "reason": "Generated local artifacts should be reproducible, ignored, or documented as fixtures."
    },
    {
      "id": "repo_ci_and_tooling",
      "risk": "medium",
      "path_globs": [
        ".github/workflows/**",
        "pyproject.toml",
        "tools/**",
        "tests/test_*tool*.py",
        "tests/test_check_*.py"
      ],
      "commands": [
        "py -m pytest -q tests\\test_check_protected_surfaces.py tests\\test_agent_hardening_tools.py",
        "py -m ruff check tools tests",
        "py tools\\check_agent_docs.py"
      ],
      "reason": "Tooling changes should prove the local safety gates still run in a clean clone."
    },
    {
      "id": "analytics_and_ai_boundary",
      "risk": "medium",
      "path_globs": [
        "src/mythic_edge_parser/app/analytics_sidecar.py",
        "src/mythic_edge_parser/app/card_performance.py",
        "src/mythic_edge_parser/app/runtime_surfaces.py",
        "tests/test_analytics_sidecar.py",
        "tests/test_card_performance.py",
        "tests/test_runtime_surfaces.py"
      ],
      "commands": [
        "py -m pytest -q tests\\test_analytics_sidecar.py tests\\test_card_performance.py tests\\test_runtime_surfaces.py"
      ],
      "reason": "Analytics should consume parser-managed facts and preserve source/confidence/finality metadata."
    }
  ]
}
