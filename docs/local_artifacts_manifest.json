      },
      "safe_checks": ["exists", "file_kind", "git_tracked"],
      "forbidden_checks": ["install_node_dependencies", "change_frontend_behavior"],
      "notes": "Local app frontend metadata."
    },
    {
      "id": "frontend_source",
      "label": "Frontend source tree",
      "classification": "Repo-Owned Source Files",
      "path_scope": "repo_relative",
