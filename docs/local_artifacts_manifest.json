{
  "schema_version": "local_artifacts_manifest.v1",
  "object": "mythic_edge_local_artifacts_manifest",
  "description": "Machine-readable classification of Mythic Edge repo-owned, generated, private, and local-only artifacts for report-only environment readiness checks.",
  "profile_aliases": {
    "analytics_dev": "analytics_development",
    "live_parser": "live_parser_readiness"
  },
  "profiles": {
    "clean_clone": {
      "label": "Clean clone",
      "description": "Fresh source checkout with no private MTGA data and no initialized local app state.",
      "artifacts": [
        "agents_md",
        "pyproject_toml",
        "gitignore",
        "source_package",
        "tests_tree",
        "tools_tree",
        "frontend_package_json",
        "frontend_source",
        "private_output_match_logs",
        "private_output_runtime_logs",
        "private_output_status_snapshots",
        "private_output_transport_failures",
        "private_output_bad_events",
        "private_output_decklists",
        "generated_analytics_data",
        "generated_card_catalog",
        "generated_tier_source_latest",
        "frontend_node_modules",
        "frontend_build_output",
        "frontend_vite_cache",
        "frontend_coverage",
        "python_caches",
        "env_files",
        "credential_json_files",
        "webhook_url_files",
        "api_key_files"
      ]
    },
    "local_developer_app": {
      "label": "Local developer app",
      "description": "Checkout that can run the local developer backend/frontend shell without requiring generated app state.",
      "artifacts": [
        "pyproject_toml",
        "local_app_package",
        "frontend_package_json",
        "frontend_source",
        "dev_app_tools",
        "app_data_root",
        "app_config_file",
        "analytics_sqlite_database",
        "app_logs_dir",
        "app_imports_dir",
        "app_jobs_dir",
        "app_diagnostics_dir",
        "sqlite_sidecar_files",
        "env_files",
        "credential_json_files"
      ]
    },
    "analytics_development": {
      "label": "Analytics development",
      "description": "Checkout that can run analytics schema, migration, ingest, and view tests from repo-owned source and synthetic data.",
      "artifacts": [
        "pyproject_toml",
        "analytics_migration_sql",
        "analytics_ingest_module",
        "analytics_legacy_jsonl_adapter",
        "analytics_schema_tests",
        "analytics_ingest_tests",
        "generated_analytics_data",
        "private_input_player_log",
        "private_input_historical_jsonl_file",
        "private_input_historical_jsonl_folder",
        "private_output_match_logs",
        "env_files"
      ]
    },
    "live_parser_readiness": {
      "label": "Live parser readiness",
      "description": "Machine intended to run the live parser against MTGA while keeping private evidence and credentials local.",
      "artifacts": [
        "main_entrypoint",
        "parser_state",
        "parser_models",
        "parser_outputs",
        "runtime_surfaces",
        "private_input_player_log",
        "private_output_match_logs",
        "private_output_runtime_logs",
        "private_output_status_snapshots",
        "private_output_transport_failures",
        "private_output_bad_events",
        "env_files",
        "webhook_url_files",
        "api_key_files"
      ]
    },
    "historical_import_readiness": {
      "label": "Historical import readiness",
      "description": "Machine intended to import selected historical JSONL artifacts through approved local import flows.",
      "artifacts": [
        "local_app_package",
        "local_app_import_jobs",
        "analytics_legacy_jsonl_adapter",
        "analytics_ingest_module",
        "analytics_manual_import_tests",
        "app_data_root",
        "analytics_sqlite_database",
        "private_input_historical_jsonl_file",
        "private_input_historical_jsonl_folder",
        "app_imports_dir",
        "app_jobs_dir",
        "env_files"
      ]
    }
  },
  "artifact_classes": {
    "Repo-Owned Source Files": {
      "description": "Tracked source, tests, docs, config, and tooling that may be committed when reviewed and in scope.",
      "default_git_policy": "tracked_allowed"
    },
    "Generated Local App State": {
      "description": "Local app state under the symbolic app data root. It is app-owned generated state and must not be committed.",
      "default_git_policy": "never_commit"
    },
    "Private Local Inputs": {
      "description": "Operator-selected or machine-local inputs such as MTGA logs, historical JSONL artifacts, and workbook exports.",
      "default_git_policy": "never_commit"
    },
    "Private Local Outputs": {
      "description": "Parser, runtime, import, or workbook-facing generated outputs that may contain private payloads or local state.",
      "default_git_policy": "ignored_required"
    },
    "Generated Nonprivate Support Data": {
      "description": "Regenerable support outputs that are not expected to be private but should not become source accidentally.",
      "default_git_policy": "ignored_required"
    },
    "Secret And Credential Surfaces": {
      "description": "Secret-adjacent files, names, and local configuration surfaces. Values must never be printed by the checker.",
      "default_git_policy": "never_commit"
    }
  },
  "artifacts": [
    {
      "id": "agents_md",
      "label": "Agent entrypoint",
      "classification": "Repo-Owned Source Files",
      "path_scope": "repo_relative",
      "path_pattern": "AGENTS.md",
      "git_policy": "tracked_allowed",
      "privacy": "public_repo_source",
      "profiles": {
        "clean_clone": {"required": true},
        "local_developer_app": {"required": true},
        "analytics_development": {"required": true}
      },
      "safe_checks": ["exists", "file_kind", "git_tracked"],
      "forbidden_checks": ["judge_policy_correctness"],
      "notes": "Short repo-local authority entrypoint."
    },
    {
      "id": "pyproject_toml",
      "label": "Python project metadata",
      "classification": "Repo-Owned Source Files",
      "path_scope": "repo_relative",
      "path_pattern": "pyproject.toml",
      "git_policy": "tracked_allowed",
      "privacy": "public_repo_source",
      "profiles": {
        "clean_clone": {"required": true},
        "local_developer_app": {"required": true},
        "analytics_development": {"required": true},
        "live_parser_readiness": {"required": true},
        "historical_import_readiness": {"required": true}
      },
      "safe_checks": ["exists", "file_kind", "git_tracked"],
      "forbidden_checks": ["install_dependencies", "edit_dependencies"],
      "notes": "Defines package metadata and optional dependency groups."
    },
    {
      "id": "gitignore",
      "label": "Git ignore policy",
      "classification": "Repo-Owned Source Files",
      "path_scope": "repo_relative",
      "path_pattern": ".gitignore",
      "git_policy": "tracked_allowed",
      "privacy": "public_repo_source",
      "profiles": {
        "clean_clone": {"required": true}
      },
      "safe_checks": ["exists", "file_kind", "git_tracked"],
      "forbidden_checks": ["edit_ignore_policy"],
      "notes": "Existing ignore policy is evidence only in this pass."
    },
    {
      "id": "source_package",
      "label": "Parser package source",
      "classification": "Repo-Owned Source Files",
      "path_scope": "repo_relative",
      "path_pattern": "src/mythic_edge_parser",
      "git_policy": "tracked_allowed",
      "privacy": "public_repo_source",
      "profiles": {
        "clean_clone": {"required": true}
      },
      "safe_checks": ["exists", "directory_kind", "git_tracked"],
      "forbidden_checks": ["change_parser_behavior"],
      "notes": "Parser source remains the owner of parser interpretation."
    },
    {
      "id": "tests_tree",
      "label": "Test suite",
      "classification": "Repo-Owned Source Files",
      "path_scope": "repo_relative",
      "path_pattern": "tests",
      "git_policy": "tracked_allowed",
      "privacy": "public_repo_source",
      "profiles": {
        "clean_clone": {"required": true}
      },
      "safe_checks": ["exists", "directory_kind", "git_tracked"],
      "forbidden_checks": ["rewrite_tests_broadly"],
      "notes": "Repo-owned tests and synthetic fixtures."
    },
    {
      "id": "tools_tree",
      "label": "Tooling scripts",
      "classification": "Repo-Owned Source Files",
      "path_scope": "repo_relative",
      "path_pattern": "tools",
      "git_policy": "tracked_allowed",
      "privacy": "public_repo_source",
      "profiles": {
        "clean_clone": {"required": true}
      },
      "safe_checks": ["exists", "directory_kind", "git_tracked"],
      "forbidden_checks": ["run_mutating_tools"],
      "notes": "Repo-owned tooling; individual tools still need scoped authorization before mutation."
    },
    {
      "id": "frontend_package_json",
      "label": "Frontend package metadata",
      "classification": "Repo-Owned Source Files",
      "path_scope": "repo_relative",
      "path_pattern": "frontend/package.json",
      "git_policy": "tracked_allowed",
      "privacy": "public_repo_source",
      "profiles": {
