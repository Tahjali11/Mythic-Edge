# Mythic Edge local environment example.
# Copy values into a local, ignored .env or shell profile. Do not commit real secrets.

# Optional override for the MTGA log path.
MTGA_PLAYER_LOG=

# Optional override for the project root when running from unusual launchers.
MYTHICEDGE_PROJECT_ROOT=

# Google Sheets webhook URL. Keep blank in committed files.
MYTHICEDGE_SHEETS_WEBHOOK=

# Optional local artifact roots.
MYTHICEDGE_MATCH_LOGS_ROOT=
MYTHICEDGE_RUNTIME_LOGS_ROOT=
MYTHICEDGE_STATUS_ROOT=
MYTHICEDGE_FAILED_POSTS_ROOT=
MYTHICEDGE_BAD_EVENTS_ROOT=
MYTHICEDGE_ORACLE_DATA_ROOT=
MYTHICEDGE_TIER_SOURCES_ROOT=
MYTHICEDGE_DECKLISTS_ROOT=

# Runtime flags.
MYTHICEDGE_POST_MATCH_LOG_ROWS=1
MYTHICEDGE_POST_GAME_LOG_ROWS=1
MYTHICEDGE_POST_RAW_EVENTS=0
MYTHICEDGE_ENABLE_STATUS_API=1
